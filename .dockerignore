# Dependencies and build output are reproduced inside the image from the frozen
# lockfile and the build, never copied from the host.
**/node_modules
**/dist
*.tsbuildinfo

# Version control and local tooling state.
.git
.github
.cache
.config
.local
.replit
.replit_integration_files

# The read-only V1 reference clone and the build-time documentation are not
# needed to build or run the image.
reference
build-prompts
docs

# Logs and OS cruft.
**/*.log
.DS_Store
Thumbs.db

# Env and secrets are never part of the build context.
.env
.env.*
