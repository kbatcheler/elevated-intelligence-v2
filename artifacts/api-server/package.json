{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "seed:tenant": "tsx src/scripts/seedTenant.ts",
    "seed:demo": "tsx src/scripts/seedDemo.ts",
    "seed:connectors": "tsx src/scripts/seedConnectors.ts",
    "anchor:sweep": "tsx src/scripts/anchorSweep.ts"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@workspace/connectors": "workspace:*",
    "@workspace/cortex": "workspace:*",
    "@workspace/db": "workspace:*",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "p-limit": "^7.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "esbuild": "^0.25.10",
    "tsx": "catalog:",
    "vitest": "catalog:"
  }
}
